[Unit]
Description=Appli Piscine Backend (FastAPI + SQLite)
After=network.target

[Service]
User=pi
WorkingDirectory=/home/pi/appli-piscine/backend
ExecStart=/home/pi/appli-piscine/backend/.venv/bin/uvicorn server:app --host 0.0.0.0 --port 8001
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
